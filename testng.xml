<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM Test Suite" verbose="1" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.orangehrm.utils.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.orangehrm.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Dashboard Tests">
        <classes>
            <class name="com.orangehrm.tests.DashboardTest"/>
        </classes>
    </test>

</suite>